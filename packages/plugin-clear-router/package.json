{
    "name": "@resora/plugin-clear-router",
    "version": "1.0.69",
    "description": "Opt-in bridge plugin for using resora return values inside clear-router handlers.",
    "publishConfig": {
        "access": "public"
    },
    "keywords": [
        "resora",
        "clear-router",
        "express",
        "h3",
        "plugin",
        "typescript"
    ],
    "homepage": "https://arkstack-hq.github.io/resora/plugins/clear-router",
    "bugs": {
        "url": "https://github.com/arkstack-hq/resora/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/arkstack-hq/resora.git",
        "directory": "packages/plugin-clear-router"
    },
    "readme": "README.md",
    "license": "MIT",
    "type": "module",
    "main": "./dist/index.cjs",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.cts",
    "exports": {
        ".": {
            "import": "./dist/index.mjs",
            "require": "./dist/index.cjs"
        },
        "./package.json": "./package.json"
    },
    "files": [
        "dist",
        "README.md"
    ],
    "scripts": {
        "test": "vitest run --config vitest.config.ts tests/*.spec.ts",
        "build": "tsdown",
        "lint": "eslint src tests --ext .ts",
        "version:patch": "pnpm version patch",
        "prepublishOnly": "pnpm build && pnpm test"
    },
    "dependencies": {
        "resora": "workspace:^"
    },
    "peerDependencies": {
        "clear-router": "^2.9.2"
    },
    "devDependencies": {
        "unplugin-swc": "^1.5.9",
        "reflect-metadata": "^0.2.2",
        "@koa/router": "^15.5.0",
        "@types/koa": "^3.0.2",
        "@types/koa__router": "^12.0.5",
        "fastify": "^5.8.5",
        "h3": "^2.0.1-rc.22",
        "hono": "^4.12.18",
        "koa": "^3.2.0",
        "parasito": "^0.1.6"
    }
}
