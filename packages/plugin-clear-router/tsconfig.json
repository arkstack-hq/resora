{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "../../",
    "baseUrl": ".",
    "moduleResolution": "bundler",
    "paths": {
      "resora": ["../../src/index.ts"],
      "@resora/plugin-clear-router": ["src/index.ts"]
    }
  },
  "include": [
    "src/**/*",
    "tests/**/*",
    "tsdown.config.ts"
  ],
  "exclude": [
    "dist",
    "node_modules"
  ]
}